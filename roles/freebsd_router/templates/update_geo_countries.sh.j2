#!/bin/sh
# Generato da Ansible - Non modificare a mano
# Popola la tabella PF <geo_countries> con i range IP dei paesi configurati.
# Il significato (whitelist o blacklist) è deciso da pf.conf in base a geoblock_mode.

set -eu

COUNTRIES="{{ geoblock_countries }}"
GEO_FILE="/var/db/geo_countries.txt"
TMP_FILE="$(mktemp /tmp/geo_countries.XXXXXX)"
trap 'rm -f "$TMP_FILE"' EXIT

# Scarica/genera i dati aggiornati su file temporaneo
/usr/local/bin/ipup -p -t "$COUNTRIES" > "$TMP_FILE"

# Verifica che il download sia riuscito e non sia vuoto
if [ ! -s "$TMP_FILE" ]; then
    echo "Errore: download fallito o file vuoto. Tabella invariata." >&2
    exit 1
fi

# Rimpiazza atomicamente il file persistente
mv "$TMP_FILE" "$GEO_FILE"
# mktemp è stato pulito dal trap; disarmalo per evitare warning sul mv
trap - EXIT

# Replace atomico della tabella PF: nessuna finestra di tabella vuota
/sbin/pfctl -t geo_countries -T replace -f "$GEO_FILE"
