server:
    verbosity: 1
    # Specifica ogni interfaccia su una riga separata
    interface: 127.0.0.1
    interface: {{ lan_ip | default('10.0.0.1') }}
    
    do-ip4: yes
    do-ip6: no
    do-udp: yes
    do-tcp: yes

    # Sicurezza: Permetti esplicitamente la tua rete 10.0.0.0/24
    access-control: 127.0.0.0/8 allow
    access-control: {{ lan_network | default('10.0.0.0/24') }} allow
    
    hide-identity: yes
    hide-version: yes

    # Performance
    prefetch: yes
    cache-min-ttl: 3600
    cache-max-ttl: 86400

forward-zone:
    name: "."
    forward-addr: 9.9.9.9        # Quad9
    forward-addr: 1.1.1.1        # Cloudflare